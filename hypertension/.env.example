# These variables are set automatically by docker-compose.yml.
# Only needed for manual (non-Docker) development.

# Zhipu Embedding API
ZHIPU_API_KEY=your_zhipu_api_key_here
EMBEDDER=zhipu
EMBED_DIM=2048

# Reranker (uses LLM_API_KEY from main .env)
RERANKER=api
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Qdrant (local Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333
